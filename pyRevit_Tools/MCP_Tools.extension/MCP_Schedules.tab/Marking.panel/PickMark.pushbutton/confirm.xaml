<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Mark" Height="140" Width="220"
        ShowInTaskbar="False" Topmost="True" WindowStyle="None"
        BorderThickness="2" BorderBrush="#FFC107">
    <Grid Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="msg_text" Text="MAU-0001" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#333333"/>
            <Button x:Name="ok_btn" Content="OK" Width="100" Height="35"
                    Background="#FFC107" Foreground="#333333" FontWeight="Bold"
                    Click="on_ok" Cursor="Hand" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
